{
    "$help": "https://aka.ms/terminal-documentation",
    "$schema": "https://aka.ms/terminal-profiles-schema",

    "defaultProfile": "{61c54bbd-c2c6-5271-96e7-009a87ff44bf}",

    "initialCols": 140,
    "initialRows": 35,

    "copyOnSelect": false,
    "copyFormatting": "none",
    "trimBlockSelection": true,

    "theme": "dark",

    "profiles": {
        "defaults": {
            "font": {
                "face": "CaskaydiaCove Nerd Font",
                "size": 13
            },
            "opacity": 95,
            "useAcrylic": true,
            "scrollbarState": "hidden",
            "cursorShape": "bar",
            "cursorColor": "#FFFFFF",
            "bellStyle": "none",
            "closeOnExit": "graceful",
            "startingDirectory": "%USERPROFILE%",
            "padding": "8"
        },
        "list": [
            {
                "guid": "{61c54bbd-c2c6-5271-96e7-009a87ff44bf}",
                "name": "PowerShell",
                "source": "Windows.Terminal.PowershellCore",
                "hidden": false
            },
            {
                "guid": "{0caa0dad-35be-5f56-a8ff-afceeeaa6101}",
                "name": "Command Prompt",
                "commandline": "%SystemRoot%\\System32\\cmd.exe",
                "hidden": false
            },
            {
                "guid": "{b453ae62-4e3d-5e58-b989-0a998ec441b8}",
                "name": "Azure Cloud Shell",
                "source": "Windows.Terminal.Azure",
                "hidden": true
            }
        ]
    },

    "schemes": [],

    "keybindings": [
        { "command": "closePane",            "keys": "ctrl+w" },
        { "command": "splitPaneDown",        "keys": "ctrl+shift+d" },
        { "command": "splitPaneRight",       "keys": "ctrl+shift+r" },
        { "command": "moveFocusDown",        "keys": "alt+j" },
        { "command": "moveFocusUp",          "keys": "alt+k" },
        { "command": "moveFocusLeft",        "keys": "alt+h" },
        { "command": "moveFocusRight",       "keys": "alt+l" },
        { "command": "newTab",               "keys": "ctrl+t" },
        { "command": "nextTab",              "keys": "ctrl+tab" },
        { "command": "prevTab",              "keys": "ctrl+shift+tab" }
    ]
}
