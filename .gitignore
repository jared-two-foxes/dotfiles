# =============================================================
# .gitignore
# =============================================================

# --- Neovim runtime artifacts --------------------------------
shared/nvim/plugin/
shared/nvim/lazy-lock.json

# --- Local machine overrides ---------------------------------
# Track machine profiles and *.template files; ignore populated copies
local/**
!local/machines/
!local/machines/**
!local/**/*.template

# PowerShell local profile (sits alongside the main profile
# after install — not in the repo)
windows/powershell/profile.local.ps1

# --- OS artifacts --------------------------------------------
.DS_Store
Thumbs.db
desktop.ini

# --- Python/test artifacts -----------------------------------
__pycache__/
*.py[cod]

# --- ticket-pipeline runtime state ---------------------------
ticket-pipeline/.pipeline-log.jsonl
